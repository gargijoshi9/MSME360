# ── Server ──────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# REQUIRED. The server will refuse to start if this is not set.
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/msme360?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string_generated_by_crypto_randomBytes
JWT_EXPIRES_IN=7d

# ── Gmail SMTP (nodemailer, service: 'gmail') ─────────────────────────────────
# Use a Gmail App Password — your regular Gmail password will NOT work.
# Generate one at: https://myaccount.google.com/apppasswords
# (Requires 2-Step Verification to be enabled on the account.)
SMTP_EMAIL=your-gmail-address@gmail.com
SMTP_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── WhatsApp Cloud API (Phase 2 — not used in Phase 1 auth module) ───────────
# WHATSAPP_VERIFY_TOKEN=your_whatsapp_verify_token
# WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ── Gmail OAuth2 / Pub/Sub (Phase 2) ─────────────────────────────────────────
# GMAIL_CLIENT_ID=your_gmail_client_id
# GMAIL_CLIENT_SECRET=your_gmail_client_secret
# GMAIL_REDIRECT_URI=http://localhost:5001/api/settings/gmail/callback
# GMAIL_PUBSUB_TOPIC=projects/<project-id>/topics/<topic-name>

# ── LLM / Classifier (Phase 2) ───────────────────────────────────────────────
# GEMINI_API_KEY=your_gemini_api_key

# ── Google Sheets (Phase 2) ──────────────────────────────────────────────────
# SHEETS_SPREADSHEET_ID=your_spreadsheet_id
